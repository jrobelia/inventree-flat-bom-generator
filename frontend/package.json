{
  "name": "inventree-flat-bom-generator",
  "private": true,
  "version": "0.11.53",
  "type": "module",
  "scripts": {
    "lint": "npx @biomejs/biome check ./src",
    "lint:fix": "npx @biomejs/biome check ./src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run lint && npm run test && npm run test:e2e",
    "build": "tsc -b && vite build --emptyOutDir",
    "dev": "vite --config vite.dev.config.ts"
  },
  "dependencies": {
    "@inventreedb/ui": "latest",
    "react": ">= 19.1.1",
    "react-dom": ">= 19.1.1",
    "@mantine/core": ">= 8.2.7",
    "@mantine/hooks": ">= 8.2.7",
    "@mantine/modals": ">= 8.2.7",
    "@mantine/notifications": ">= 8.2.7",
    "mantine-datatable": "^8.2.0"
  },
  "peerDependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.0.0",
    "@playwright/test": "^1.48.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^4.7.0",
    "globals": "^15.14.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vite-plugin-externals": "^0.6.2",
    "vitest": "^4.0.17"
  }
}